# VoxBridge environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to git.

# --- AI Backend ---
# Choose ONE: "openai" or "ollama"
AI_BACKEND=openai

# OpenAI settings (only if AI_BACKEND=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama settings (only if AI_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Speech-to-Text ---
# Whisper model: tiny, base, small, medium, large
WHISPER_MODEL=base

# --- Language ---
# ISO language code: en, de, fa, etc.
LANGUAGE=en
